```gitignore
# PowerShell profiles and temporary files
Microsoft.PowerShell_profile.ps1
profile.ps1
*.tmp
*.temp

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# OS generated files
.DS_Store
Thumbs.db

# Dependencies
node_modules/
venv/
.venv/
__pycache__/
*.egg-info/

# Build artifacts
dist/
build/
target/
*.pyc
*.class
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Coverage reports
coverage/
htmlcov/
.coverage

# Editors
.vscode/
.idea/
*.swp
*.swo

# Gradle
.gradle/

# MyPy
.mypy_cache/

# Pytest
.pytest_cache/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```